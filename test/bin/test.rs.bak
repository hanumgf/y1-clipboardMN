use std::error::Error;
use std::fs::File;
use std::io::Write;
use std::os::fd::OwnedFd;
use wayland_client::{protocol::wl_registry, Connection, Dispatch, QueueHandle};
use wayland_client::protocol::wl_seat::WlSeat;
use wayland_protocols::ext::data_control::v1::client::{
    ext_data_control_device_v1::{self, ExtDataControlDeviceV1},
    ext_data_control_manager_v1::{ExtDataControlManagerV1},
    ext_data_control_offer_v1::{self, ExtDataControlOfferV1},
    ext_data_control_source_v1::{self, ExtDataControlSourceV1},
};

struct CopyTestState {
    manager: Option<ExtDataControlManagerV1>,
    seat: Option<WlSeat>,
    target_mime: String,
    tx_buf: Vec<u8>,
}

impl Dispatch<ExtDataControlSourceV1, ()> for CopyTestState {
    fn event(
        state: &mut Self,
        _source: &ExtDataControlSourceV1,
        event: ext_data_control_source_v1::Event,
        _data: &(),
        _conn: &Connection,
        _qh: &QueueHandle<Self>,
    ) {
        match event {
            ext_data_control_source_v1::Event::Send { mime_type, fd } => {
                println!("➡️ [Gatekeeper] Compositor data control request signaled. (MIME: {mime_type})");
                if mime_type == state.target_mime {
                    if let Ok(cloned_fd) = fd.try_clone() {
                        let mut file = File::from(cloned_fd);
                        if let Err(e) = file.write_all(&state.tx_buf) {
                            eprintln!("❌ Failed to pipe egress stream array: {e}");
                        } else {
                            let _ = file.flush();
                            println!("   ✅ Data successfully streamed to OS socket bounds.");
                        }
                    }
                }
            }
            ext_data_control_source_v1::Event::Cancelled => {
                println!("🚫 [Gatekeeper] Clipboard ownership lost. Terminating action loop context.");
                std::process::exit(0);
            }
            _ => {}
        }
    }
}

impl Dispatch<ExtDataControlDeviceV1, ()> for CopyTestState {
    fn event(_: &mut Self, _: &ExtDataControlDeviceV1, _: ext_data_control_device_v1::Event, _: &(), _: &Connection, _: &QueueHandle<Self>) {}
    
    wayland_client::event_created_child!(CopyTestState, ExtDataControlDeviceV1, [
        ext_data_control_device_v1::EVT_DATA_OFFER_OPCODE => (ExtDataControlOfferV1, ())
    ]);
}

fn main() -> Result<(), Box<dyn Error>> {
    let conn = Connection::connect_to_env().map_err(|e| {
        eprintln!("❌ Missing Wayland compositor context. Are you currently inside a Wayland session?");
        e
    })?;
    
    let mut event_queue = conn.new_event_queue();
    let qh = event_queue.handle();
    conn.display().get_registry(&qh, ());

    let mut state = CopyTestState { 
        manager: None, 
        seat: None,
        target_mime: "text/plain".to_string(),
        tx_buf: b"SUCCESS1.0: DB kara modoshita data da!!".to_vec(),
    };

    println!("1. Aligning protocol manager nodes (Executing high-speed loop synchronizations)...");
    
    event_queue.roundtrip(&mut state)?;

    let (Some(manager), Some(seat)) = (state.manager.as_ref(), state.seat.as_ref()) else {
        eprintln!("❌ Critical Error: Missing required clipboard protocol extensions inside active environment.");
        std::process::exit(1);
    };

    let source = manager.create_data_source(&qh, ());
    source.offer(state.target_mime.clone());
    
    let device = manager.get_data_device(seat, &qh, ());
    device.set_selection(Some(&source));
    let _ = conn.flush();

    println!("2. 🚀 Selection envelope asserted successfully. (wl-copy mode initialized)");
    println!("   [Diagnostic Verification Step]");
    println!("   Leave this operational terminal tab open, switch to any input layout channel,");
    println!("   and trigger standard terminal clipboard paste routines (e.g., Ctrl + V).");

    loop {
        event_queue.blocking_dispatch(&mut state)?;
    }
}

impl Dispatch<wl_registry::WlRegistry, ()> for CopyTestState {
    fn event(state: &mut Self, reg: &wl_registry::WlRegistry, ev: wl_registry::Event, _: &(), _: &Connection, qh: &QueueHandle<Self>) {
        if let wl_registry::Event::Global { name, interface, version } = ev {
            match interface.as_str() {
                "ext_data_control_manager_v1" => state.manager = Some(reg.bind::<ExtDataControlManagerV1, _, _>(name, version.min(1), qh, ())),
                "wl_seat" if state.seat.is_none() => state.seat = Some(reg.bind::<WlSeat, _, _>(name, version, qh, ())),
                _ => {}
            }
        }
    }
}
impl Dispatch<ExtDataControlManagerV1, ()> for CopyTestState { fn event(_: &mut Self, _: &ExtDataControlManagerV1, _: wayland_protocols::ext::data_control::v1::client::ext_data_control_manager_v1::Event, _: &(), _: &Connection, _: &QueueHandle<Self>) {} }
impl Dispatch<ExtDataControlOfferV1, ()> for CopyTestState { fn event(_: &mut Self, _: &ExtDataControlOfferV1, _: ext_data_control_offer_v1::Event, _: &(), _: &Connection, _: &QueueHandle<Self>) {} }
impl Dispatch<WlSeat, ()> for CopyTestState { fn event(_: &mut Self, _: &WlSeat, _: wayland_client::protocol::wl_seat::Event, _: &(), _: &Connection, _: &QueueHandle<Self>) {} }
