#compdef y1-clipboard

_y1_clipboard() {
    local context state state_descr line
    typeset -A opt_args

    # 1. Define technical descriptions for each subcommand
    local -a _y1_cmds
    _y1_subcommands=(
        'daemon:Monitor clipboard changes in background'
        'list:Display history metadata records'
        'search:Keyword scan across text history'
        'copy-to:Restore a history entry to system clipboard'
        'show:Inspect record content or dump raw bytes'
        'store:Ingest stdin to database and sync clipboard'
        'paste-from:Stream system clipboard directly to stdout'
        'delete:Physically remove a specific record'
        'wipe:Purge all history and optimize storage'
        'version:Display version information'
        'help:Display help information'
    )

    # 2. Configure global options and the primary dispatcher
    # Using '-s' to enable short flag stacking (e.g., -RA, -vR)
    _arguments -s -S \
        '(-h --help)'{-h,--help}'[Show help information]' \
        '(-V --version)'{-V,--version}'[Show version information]' \
        '1: :->cmds' \
        '*:: :->args'

    case $state in
        cmds)
            _describe -t commands 'y1-clipboard commands' _y1_subcommands
            ;;
        args)
            case $words[1] in
                daemon)
                    _arguments -s -S \
                        '(-v --verbose)'{-v,--verbose}'[Enable detailed event logging]'
                    ;;
                list)
                    _arguments -s -S \
                        '(-R --raw)'{-R,--raw}'[Clean output for scripting]' \
                        '(-A --full)'{-A,--full}'[Display all history entries]' \
                        '::range (e.g. 0-50):'
                    ;;
                search)
                    _arguments -s -S \
                        '(-R --raw)'{-R,--raw}'[Clean output for scripting]' \
                        ':query text:'
                    ;;
                show)
                    _arguments -s -S \
                        '(-R --raw)'{-R,--raw}'[Output exact binary data]' \
                        ':id:'
                    ;;
                copy-to|delete)
                    _arguments ':id:'
                    ;;
                wipe)
                    _arguments -s -S \
                        '(-f --force)'{-f,--force}'[Bypass confirmation prompt]'
                    ;;
                store|paste-from)
                    local -a mimes
                    mimes=('text/plain' 'text/plain;charset=utf-8' 'image/png' 'image/jpeg' 'text/html')
                    _values 'mime type' $mimes[@]
                    ;;
            esac
            ;;
    esac
}

_y1_clipboard "$@"
